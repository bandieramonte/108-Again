{
  "compilerOptions": {
    "baseUrl": "../..",
    "jsx": "react-native",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../.build",
    "rootDir": "../..",
    "strict": true,
    "target": "ES2020",
    "noEmit": false,
    "noEmitOnError": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "skipLibCheck": true
