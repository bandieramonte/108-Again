    "../../i18n/languageDetection.ts",
    "../../i18n/languagePreference.ts",
    "../../i18n/locales/en.ts",
    "../../i18n/locales/es.ts",
    "../../i18n/locales/ru.ts",
    "../../i18n/locales/de.ts",
    "../../i18n/locales/pl.ts",
    "../../i18n/locales/cs.ts",
    "../../i18n/locales/hu.ts",
    "../../repositories/appMetaRepoFactory.ts",
    "../../repositories/deletedRecordRepoFactory.ts",
    "../../repositories/practiceRepoFactory.ts",
    "../../repositories/sessionRepoFactory.ts",
    "../../services/appOperationEngine.ts",
    "../../services/appOperationRuntime.ts",
    "../../services/authAccountActions.ts",
    "../../services/authAccountGuard.ts",
    "../../services/backupService.ts",
    "../../services/authSessionPolicy.ts",
    "../../services/appUpdatePolicy.ts",
    "../../services/lastPracticeScreenService.ts",
    "../../services/practiceReminderService.ts",
    "../../services/syncCoordinator.ts",
    "../../services/syncEngine.ts",
    "../../supabase/functions/send-auth-email/renderAuthEmail.ts",
    "../../types/sync.ts",
    "../../utils/authErrorText.ts",
    "../../utils/dateUtils.ts",
    "../../utils/headerBackVisibility.ts",
    "../../utils/practiceReminderState.ts",
    "../../utils/reminderTime.ts",
    "../../utils/numberUtils.ts"
  ]
